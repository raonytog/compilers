# Comando do compilador Java
JAVAC=javac

# Comando da JVM
JAVA=java

# ROOT ÂŽe a raiz dos diretÂŽorios com todos os roteiros de laboratÂŽorios
YEAR=$(shell pwd | grep -o â20..-.â)
ROOT=/home/rtgomes/Documents/compilers

# Caminho para o JAR do ANTLR em labs/tools
ANTLR_PATH=$(ROOT)/tools/antlr-4.13.2-complete.jar

# OpcÂžËao de configuracÂžËao do CLASSPATH para o ambiente Java
CLASS_PATH_OPTION=-cp .:$(ANTLR_PATH)

# ConfiguracÂžËao do comando de compilacÂžËao do ANTLR
ANTLR4=$(JAVA) -jar $(ANTLR_PATH)

# ConfiguracÂžËao do ambiente de teste do ANTLR
GRUN=$(JAVA) $(CLASS_PATH_OPTION) org.antlr.v4.gui.TestRig

# Nome da gramÂŽatica
GRAMMAR_NAME=entrada

# DiretÂŽorio para aonde vËao os arquivos gerados
GEN_PATH=lexer

# Executa o ANTLR e o compilador Java
all: antlr javac
	@echo "Done."

# Executa o ANTLR para compilar a gramÂŽatica
antlr: $(GRAMMAR_NAME).g
	$(ANTLR4) -o $(GEN_PATH) $(GRAMMAR_NAME).g

# Executa o javac para compilar os arquivos gerados
javac:
	$(JAVAC) $(CLASS_PATH_OPTION) $(GEN_PATH)/*.java

# Executa o lexer. Comando: $ make run FILE=arquivo_de_teste
run:
	cd $(GEN_PATH) && $(GRUN) $(GRAMMAR_NAME) tokens -tokens $(FILE)

# Remove os arquivos gerados pelo ANTLR
clean:
	@rm -rf $(GEN_PATH)